# Agency OS — Environment Variables
# Copy this file to .env and fill in your values
# .env is gitignored — your keys stay local

# ── API Keys ──
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ── Service Platform ──
# PLATFORM_API_KEY=...

# ── Analytics ──
# ANALYTICS_API_KEY=...

# ── Project Management ──
# FREELO_EMAIL=your@email.com
# FREELO_API_KEY=...

# ── Other Integrations ──
# FATHOM_API_KEY=...
# KIE_API_KEY=...
