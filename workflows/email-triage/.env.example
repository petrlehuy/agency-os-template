# Anthropic API key (for Claude classification + drafting)
ANTHROPIC_API_KEY=sk-ant-...

# Slack Bot Token (needs chat:write scope)
SLACK_BOT_TOKEN=xoxb-...

# Slack channel for triage summaries
SLACK_CHANNEL=#inbox-triage

# Gmail OAuth tokens (JSON strings)
# Each is a JSON object with: token, refresh_token, token_uri, client_id, client_secret
# Generate these using the setup script (see workflows/daily-triage.md)
GMAIL_TOKEN_PERSONAL={"token": "...", "refresh_token": "...", "token_uri": "https://oauth2.googleapis.com/token", "client_id": "...", "client_secret": "..."}
GMAIL_TOKEN_AGENTHIC={"token": "...", "refresh_token": "...", "token_uri": "https://oauth2.googleapis.com/token", "client_id": "...", "client_secret": "..."}
GMAIL_TOKEN_RETENTIONUP={"token": "...", "refresh_token": "...", "token_uri": "https://oauth2.googleapis.com/token", "client_id": "...", "client_secret": "..."}
